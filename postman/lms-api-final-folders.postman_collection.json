    {
      "name": "09. Tien do Tot nghiep",
      "description": "Hoc vien ghi danh, danh dau hoan thanh bai hoc, theo doi tien do 100% va cap chung chi.",
      "item": [
        {
          "name": "01. Hoc vien ghi danh khoa hoc",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Ghi danh thanh cong', function () {",
                  "  pm.expect(pm.response.code).to.be.oneOf([200, 201]);",
                  "});",
                  "",
                  "const json = pm.response.json();",
                  "if (json.id) { pm.collectionVariables.set('enrollmentId', json.id); }",
                  "if (json.userId) { pm.collectionVariables.set('learnerUserId', json.userId); }",
                  "if (json.courseId) { pm.collectionVariables.set('courseId', json.courseId); }"
                ]
              }
            }
          ],
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{learnerToken}}",
                  "type": "string"
                }
              ]
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"courseId\": {{courseId}}\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/enrollments",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
