{
  "info": {
    "_postman_id": "a5b5af1e-2352-4ad0-a3f3-3fd37e2d6c31",
    "name": "LMS API - Quan ly Kiem tra & Tien do Tot nghiep",
    "description": "Hai thu muc Postman cuoi cho luong quiz, cau hoi JSONB, nop bai tu dong cham diem, tien do bai hoc va cap chung chi.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "08. Quan ly Kiem tra",
      "description": "Giang vien/Admin tao quiz va cau hoi; hoc vien nop bai va xem ket qua.",
      "item": [
        {
          "name": "01. Tao bai kiem tra",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Tao quiz thanh cong', function () {",
                  "  pm.expect(pm.response.code).to.be.oneOf([200, 201]);",
                  "});",
                  "",
                  "const json = pm.response.json();",
                  "if (json.id) { pm.collectionVariables.set('quizId', json.id); }",
                  "if (json.moduleId) { pm.collectionVariables.set('moduleId', json.moduleId); }",
                  "if (json.courseId) { pm.collectionVariables.set('courseId', json.courseId); }"
                ]
              }
            }
          ],
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{instructorToken}}",
                  "type": "string"
                }
              ]
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Bai kiem tra cuoi chuong\",\n  \"passingScore\": 70,\n  \"timeLimitMinutes\": 30,\n  \"moduleId\": {{moduleId}}\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/quizzes",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "quizzes"
              ]
            }
          },
          "response": []
        },
        {
          "name": "02. Tao cau hoi JSONB - Cau 1",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Tao cau hoi 1 thanh cong', function () {",
                  "  pm.expect(pm.response.code).to.be.oneOf([200, 201]);",
                  "});",
                  "",
                  "const json = pm.response.json();",
                  "pm.expect(json.options).to.be.an('object');",
                  "if (json.id) { pm.collectionVariables.set('question1Id', json.id); }"
                ]
              }
            }
          ],
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{instructorToken}}",
                  "type": "string"
                }
              ]
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"content\": \"PostgreSQL dung kieu du lieu nao de luu dap an A, B, C, D linh hoat?\",\n  \"options\": {\n    \"A\": \"JSONB\",\n    \"B\": \"VARCHAR\",\n    \"C\": \"BOOLEAN\",\n    \"D\": \"DATE\"\n  },\n  \"correctAnswer\": \"A\",\n  \"quizId\": {{quizId}}\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/questions",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "questions"
              ]
            }
          },
          "response": []
        },
        {
          "name": "03. Tao cau hoi JSONB - Cau 2",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Tao cau hoi 2 thanh cong', function () {",
                  "  pm.expect(pm.response.code).to.be.oneOf([200, 201]);",
                  "});",
                  "",
                  "const json = pm.response.json();",
                  "pm.expect(json.options).to.be.an('object');",
                  "if (json.id) { pm.collectionVariables.set('question2Id', json.id); }"
                ]
              }
            }
          ],
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{instructorToken}}",
                  "type": "string"
                }
              ]
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"content\": \"Endpoint nao dung de hoc vien nop bai va cham diem tu dong?\",\n  \"options\": {\n    \"A\": \"GET /api/v1/quizzes/{id}\",\n    \"B\": \"POST /api/v1/quizzes/submit\",\n    \"C\": \"DELETE /api/v1/questions/{id}\",\n    \"D\": \"PUT /api/v1/modules/{id}\"\n  },\n  \"correctAnswer\": \"B\",\n  \"quizId\": {{quizId}}\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/questions",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "questions"
              ]
            }
          },
          "response": []
        },
        {
          "name": "04. Lay cau hoi theo bai kiem tra",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Lay danh sach cau hoi thanh cong', function () {",
                  "  pm.response.to.have.status(200);",
                  "  pm.expect(pm.response.json()).to.have.property('content');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{learnerToken}}",
                  "type": "string"
                }
              ]
            },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v1/questions/quiz/{{quizId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "questions",
                "quiz",
                "{{quizId}}"
              ]
            }
          },
          "response": []
        },
        {
          "name": "05. Nop bai va cham diem tu dong",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Nop bai thanh cong', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "",
                  "const json = pm.response.json();",
                  "pm.expect(json).to.have.property('score');",
                  "pm.expect(json).to.have.property('status');",
                  "if (json.attemptId) { pm.collectionVariables.set('attemptId', json.attemptId); }"
                ]
              }
            }
          ],
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{learnerToken}}",
                  "type": "string"
                }
              ]
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"quizId\": {{quizId}},\n  \"answers\": {\n    \"{{question1Id}}\": \"A\",\n    \"{{question2Id}}\": \"B\"\n  }\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/quizzes/submit",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "quizzes",
                "submit"
              ]
            }
          },
          "response": []
        },
        {
          "name": "06. Xem ket qua lan lam bai",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Lay ket qua thanh cong', function () {",
