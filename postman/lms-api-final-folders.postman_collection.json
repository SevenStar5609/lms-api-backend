        {
          "name": "03. Mark as Done - Hoan thanh bai hoc",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Danh dau bai hoc thanh cong', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "",
                  "const text = pm.response.text();",
                  "const match = text.match(/([0-9]+(?:\\.[0-9]+)?)%/);",
                  "if (match) { pm.collectionVariables.set('currentProgress', match[1]); }"
                ]
              }
            }
          ],
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{learnerToken}}",
                  "type": "string"
                }
              ]
            },
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v1/enrollments/{{enrollmentId}}/lessons/{{lessonId}}/complete",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "enrollments",
                "{{enrollmentId}}",
                "lessons",
                "{{lessonId}}",
                "complete"
              ]
            }
          },
          "response": []
        },
